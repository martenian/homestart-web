{% macro icon(name) %}
  {% if name == "savings" %}
  <svg class="feature-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="8" ry="2"/><path d="M4 5v6c0 1.1 3.6 2 8 2s8-.9 8-2V5"/><path d="M4 11v6c0 1.1 3.6 2 8 2s8-.9 8-2v-6"/></svg>
  {% elif name == "cash" %}
  <svg class="feature-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 10v4M9 12h6"/><path d="M6 10h.01M18 14h.01"/></svg>
  {% elif name == "afford" %}
  <svg class="feature-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><path d="M7 12l4-4 4 4 5-5"/><path d="M21 16H9"/></svg>
  {% elif name == "link" %}
  <svg class="feature-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 1 7.07 0l.71.71a5 5 0 0 1-7.07 7.07l-.71-.71"/><path d="M14 11a5 5 0 0 0-7.07 0l-.71.71a5 5 0 0 0 7.07 7.07l.71-.71"/></svg>
  {% elif name == "roadmap" %}
  <svg class="feature-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h5l2 3h11"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="18" r="3"/><path d="M9 18h6"/></svg>
  {% endif %}
{% endmacro %}
